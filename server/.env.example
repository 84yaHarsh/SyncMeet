NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
JWT_SECRET=replace-with-a-long-random-secret-never-commit-the-real-value

# WebRTC ICE servers.
# STUN_URLS: comma-separated list. Falls back to Google's public STUN if unset.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN is required for reliable connectivity behind restrictive NATs/firewalls.
# Leave blank to run STUN-only (works on open networks, will fail on many
# corporate/mobile networks). Get free/dev credentials from a provider such as
# Twilio, Xirsys, Cloudflare Calls, or metered.ca, or self-host coturn.
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
